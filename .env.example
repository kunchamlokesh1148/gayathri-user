# Rename this file to .env and fill in your Firebase project credentials
# If these variables are left empty or omitted, the application will automatically
# operate in local Mock Database mode (using localStorage) for easy testing.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_RESEND_API_KEY=
VITE_RESEND_FROM_EMAIL=

